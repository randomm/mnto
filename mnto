#!/usr/bin/env bash
set -euo pipefail

# mnto — Minimalist task orchestrator
# Usage: mnto "goal" | mnto --resume {tid} | mnto --list | mnto --dry-run | mnto --plan-model {url} | mnto --vipune

# SCRIPT_DIR can be overridden via env for testing
SCRIPT_DIR="${SCRIPT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"
readonly SCRIPT_DIR
readonly BB_DIR=".mnto/bb"

# Backward compatibility: detect existing .bb/ and migrate
if [[ -d ".bb" ]] && [[ ! -L ".bb" ]] && [[ -n "$(ls -A .bb 2>/dev/null)" ]] && [[ ! -d ".mnto/bb" ]]; then
	# Security: Verify ownership before migration
	_owner="$(stat -c '%u' .bb 2>/dev/null || stat -f '%u' .bb 2>/dev/null)"
	if [[ "$_owner" != "$(id -u)" ]]; then
		echo "ERROR: .bb is owned by another user (uid $_owner). Manual migration required." >&2
		exit 1
	fi

	# Security: Require explicit opt-in for migration
	if [[ "${MIGRATE_BB:-}" != "yes" ]]; then
		echo "WARNING: Found existing .bb/ tasks. To migrate, run with MIGRATE_BB=yes" >&2
		exit 1
	fi

	echo "Migrating .bb/ to .mnto/bb/..."
	mkdir -p .mnto
	# Atomic non-clobbering move
	mv -n .bb .mnto/bb
	echo "Migration complete. Your tasks are now in .mnto/bb/"
fi

# Dependency tree:
# mnto
# ├── openai.bash (OpenAI backend implementation)
# ├── blackboard.bash
# ├── backend.bash (unified inference abstraction — depends on openai.bash)
# ├── planner.bash
# ├── context.bash (depends on: blackboard.bash)
# ├── workflow.bash (depends on: blackboard.bash, backend.bash, planner.bash, context.bash)
# └── maintenance.bash (depends on: blackboard.bash)

# Source library functions (openai.bash before backend.bash for _infer_openai)
source "$SCRIPT_DIR/lib/openai.bash"
source "$SCRIPT_DIR/lib/blackboard.bash"
source "$SCRIPT_DIR/lib/backend.bash"
source "$SCRIPT_DIR/lib/maintenance.bash"
source "$SCRIPT_DIR/lib/planner.bash"
source "$SCRIPT_DIR/lib/context.bash"
source "$SCRIPT_DIR/lib/workflow.bash"
source "$SCRIPT_DIR/lib/direct.bash"

# Global options
declare -a REMAINING_ARGS
DRY_RUN="${DRY_RUN:-false}"
VIPUNE_ENABLED="${VIPUNE_ENABLED:-false}"
PLAN_MODEL="${PLAN_MODEL:-apfel}"
PROPOSER_MODEL="${PROPOSER_MODEL:-}"
VERIFIER_MODEL="${VERIFIER_MODEL:-}"
CLEAN_MODE="${CLEAN_MODE:-false}"
PRUNE_MODE="${PRUNE_MODE:-false}"
CLEAN_DAYS="${CLEAN_DAYS:-30}"

usage() {
	cat <<EOF
Usage: mnto "goal" | mnto [options]

Commands:
  mnto "goal"           Create and run new task
  mnto --resume {tid}   Resume existing task from last state
  mnto --list           List tasks with goal snippets and status
  mnto --clean [--days N] [--dry-run]
                        Remove tasks older than N days (default: 30)
  mnto --prune [--dry-run]
                        Remove completed tasks only (have output)

Options:
  -h, --help            Show this help
  --dry-run             Show actions without executing (also --clean, --prune)
  --plan-model {url}    Use external model (legacy alias for --proposer)
  --proposer {spec}     Model spec for proposer/planner/stitcher (apfel or openai:URL:MODEL)
  --verifier {spec}     Model spec for verifier (apfel or openai:URL:MODEL)
  --vipune              Enable vipune semantic search integration

Model selection precedence:
  --proposer/--verifier > MNTO_PROPOSER/MNTO_VERIFIER > MNTO_MODEL > apfel
EOF
}

list_tasks() {
	if [[ ! -d "$BB_DIR" ]]; then
		echo "No tasks found"
		return 0
	fi

	# Enhanced list with goal snippet, subtask counts, and status
	for task_dir in "$BB_DIR"/*/; do
		if [[ -d "$task_dir" ]]; then
			local tid
			tid="$(basename "$task_dir")"

			# Get goal snippet
			local snippet
			snippet="$(get_goal_snippet "$tid")"

			# Get subtask counts
			local counts
			counts="$(count_subtasks "$tid")"
			read -r w d c f <<<"$counts"

			# Get overall task status
			local status
			status="$(get_task_status "$tid")"

			# Format: {tid} {goal_snippet} {w|d|c|f} {status}
			printf '%s %s %s/%s/%s/%s %s\n' "$tid" "$snippet" "$w" "$d" "$c" "$f" "$status"
		fi
	done
}

create_task() {
	local goal="$1"

	# Check for vipune integration
	if [[ "$VIPUNE_ENABLED" == "true" ]]; then
		# Search for relevant context
		local vipune_context
		vipune_context="$(vipune_search "$goal")"
		if [[ -n "$vipune_context" ]]; then
			# Prepend vipune results to goal
			goal="$goal$vipune_context"
		fi
	fi

	mkdir -p "$BB_DIR"

	# Generate task ID (with collision detection)
	local tid
	tid="$(gen_id)"
	local bb_dir="$BB_DIR/$tid"

	# Create task directory
	mkdir -p "$bb_dir"

	# Save goal
	echo "$goal" >"$bb_dir/g"

	# Smart routing: short/simple goals bypass the harness entirely.
	# Research shows single-agent systems outperform multi-agent on
	# sequential reasoning with matched token budgets.
	if is_direct_task "$goal"; then
		if run_direct "$tid"; then
			echo "Created task: $tid"
			return 0
		else
			echo "ERROR: Direct mode failed, falling back to harness" >&2
			# Fall through to harness
		fi
	fi

	# Generate plan using planner module (uses infer backend)
	local plan
	local plan_result
	plan="$(generate_plan "$goal")"
	plan_result=$?

	# Validate bb_dir before any cleanup (guards both error paths below)
	if ! _validate_bb_path "$bb_dir"; then
		echo "ERROR: Refusing to remove invalid path: $bb_dir" >&2
		exit 1
	fi

	if [[ $plan_result -ne 0 ]]; then
		# Exit code from generate_plan contains the error reason
		rm -rf "$bb_dir"
		exit "$plan_result"
	fi

	if [[ -z "$plan" ]]; then
		echo "ERROR: Failed to generate plan" >&2
		rm -rf "$bb_dir"
		exit 1
	fi

	# Parse plan into structure
	parse_plan "$plan" "$tid"

	# Run the workflow executor
	run_workflow "$tid"

	echo "Created task: $tid"
}

resume_task() {
	local tid="$1"
	if ! validate_id "$tid"; then
		echo "ERROR: Invalid task ID format" >&2
		exit 1
	fi
	local bb_dir="$BB_DIR/$tid"

	if [[ ! -d "$bb_dir" ]]; then
		echo "ERROR: Task '$tid' not found" >&2
		exit 1
	fi

	# Read current state and find next ready subtasks
	local status_file="$bb_dir/s"
	if [[ ! -f "$status_file" ]]; then
		echo "ERROR: Task '$tid' has no status file" >&2
		exit 1
	fi

	# Get all ready subtasks (those with all deps satisfied)
	local ready_tasks
	ready_tasks="$(get_ready_tasks "$tid")"

	if [[ -z "$ready_tasks" ]]; then
		# Check if all are complete (final state)
		local incomplete
		incomplete="$(awk '$2 != "f" {count++} END {print count+0}' "$status_file")"
		if ((incomplete == 0)); then
			# All done - write terminal outputs
			print_status "INFO" "All subtasks complete, writing outputs"
			_write_terminal_outputs "$tid"
			print_status "PASS" "Task $tid completed (resumed)"
		else
			print_status "FAIL" "No ready tasks but task not complete (possible DAG deadlock)"
			exit 1
		fi
	else
		# Process ready subtasks using workflow logic
		print_status "INFO" "Resuming task $tid with ready subtasks: $ready_tasks"

		# Build in-degree map for remaining work
		declare -A in_degree
		declare -A dependents
		local -a all_subtasks=()

		while IFS=' ' read -r id state _retries deps; do
			[[ -z "$id" ]] && continue
			all_subtasks+=("$id")
			local count=0
			if [[ -n "$deps" ]]; then
				for dep in $(echo "$deps" | tr ',' ' '); do
					count=$((count + 1))
				done
			fi
			in_degree[$id]=$count
		done <"$status_file"

		# Build reverse dependency map
		for subtask in "${all_subtasks[@]}"; do
			local st_deps
			st_deps="$(get_task_deps "$tid" "$subtask")"
			if [[ -n "$st_deps" ]]; then
				for dep in $(echo "$st_deps" | tr ',' ' '); do
					dependents[$dep]="${dependents[$dep]:-}${dependents[$dep]:+,}$subtask"
				done
			fi
		done

		# Initialize ready queue with currently ready tasks
		local -a ready_queue=()
		for rt in $ready_tasks; do
			ready_queue+=("$rt")
		done

		# Circuit breaker state
		local max_consecutive_failures="${MNTO_CIRCUIT_BREAKER:-3}"
		local consecutive_failures=0

		# Process ready queue using Kahn's algorithm
		while [[ ${#ready_queue[@]} -gt 0 ]]; do
			local current="${ready_queue[0]}"
			ready_queue=("${ready_queue[@]:1}")

			if [[ -z "$current" ]]; then
				continue
			fi

			print_status "INFO" "Processing subtask $current"

			if ! process_subtask "$tid" "$current"; then
				consecutive_failures=$((consecutive_failures + 1))
				print_status "FAIL" "Subtask $current: max retries exceeded or failed"

				if ((consecutive_failures >= max_consecutive_failures)); then
					print_status "FAIL" "Circuit breaker triggered"
					exit 1
				fi
			else
				consecutive_failures=0

				# Decrement in-degree of dependents; enqueue if now ready
				local dep_deps="${dependents[$current]:-}"
				if [[ -n "$dep_deps" ]]; then
					for dependent in $(echo "$dep_deps" | tr ',' ' '); do
						in_degree[$dependent]=$((in_degree[$dependent] - 1))
						if [[ "${in_degree[$dependent]}" == "0" ]]; then
							ready_queue+=("$dependent")
						fi
					done
				fi
			fi

			# Get any newly ready tasks
			local new_ready
			new_ready="$(get_ready_tasks "$tid")"
			for nr in $new_ready; do
				local found=false
				for q in "${ready_queue[@]}"; do
					if [[ "$q" == "$nr" ]]; then
						found=true
						break
					fi
				done
				if ! "$found"; then
					# Check if already processed (final state)
					local state
					state="$(awk -v s="$nr" '$1==s {print $2}' "$status_file")"
					if [[ "$state" != "f" ]]; then
						ready_queue+=("$nr")
					fi
				fi
			done
		done

		# Write terminal outputs
		_write_terminal_outputs "$tid"
		print_status "PASS" "Task $tid completed (resumed)"
	fi

	echo "Resumed task: $tid"
}

parse_options() {
	local _remaining_args=()
	while [[ $# -gt 0 ]]; do
		case "$1" in
		-h | --help)
			usage
			exit 0
			;;
		--dry-run)
			DRY_RUN="true"
			shift
			;;
		--plan-model)
			if [[ $# -lt 2 ]]; then
				echo "ERROR: --plan-model requires a URL or command" >&2
				exit 1
			fi
			PLAN_MODEL="$2"
			shift 2
			;;
		--proposer)
			if [[ $# -lt 2 ]]; then
				echo "ERROR: --proposer requires a model spec (apfel or openai:URL:MODEL)" >&2
				exit 1
			fi
			PROPOSER_MODEL="$2"
			shift 2
			;;
		--verifier)
			if [[ $# -lt 2 ]]; then
				echo "ERROR: --verifier requires a model spec (apfel or openai:URL:MODEL)" >&2
				exit 1
			fi
			VERIFIER_MODEL="$2"
			shift 2
			;;
		--vipune)
			VIPUNE_ENABLED="true"
			shift
			;;
		--clean)
			CLEAN_MODE="true"
			shift
			;;
		--prune)
			PRUNE_MODE="true"
			shift
			;;
		--days)
			if [[ $# -lt 2 ]]; then
				echo "ERROR: --days requires a number" >&2
				exit 1
			fi
			if ! [[ "$2" =~ ^[0-9]+$ ]]; then
				echo "ERROR: --days requires a positive integer" >&2
				exit 1
			fi
			CLEAN_DAYS="$2"
			shift 2
			;;
		-*)
			echo "ERROR: Unknown option: $1" >&2
			usage
			exit 1
			;;
		*)
			_remaining_args+=("$1")
			shift
			;;
		esac
	done
	REMAINING_ARGS=("${_remaining_args[@]}")
}

main() {
	if [[ $# -eq 0 ]]; then
		usage
		exit 1
	fi

	# Parse global options first
	parse_options "$@"
	set -- "${REMAINING_ARGS[@]}"

	# Backward compatibility: map --plan-model to PROPOSER when --proposer not set
	if [[ -n "$PLAN_MODEL" ]] && [[ -z "$PROPOSER_MODEL" ]]; then
		PROPOSER_MODEL="$PLAN_MODEL"
	fi

	# Precedence: CLI flags override pre-set env vars
	if [[ -n "$PROPOSER_MODEL" ]]; then
		export MNTO_PROPOSER="$PROPOSER_MODEL"
	fi
	if [[ -n "$VERIFIER_MODEL" ]]; then
		export MNTO_VERIFIER="$VERIFIER_MODEL"
	fi

	case "$1" in
	-h | --help)
		usage
		exit 0
		;;
	--list)
		list_tasks
		;;
	--resume)
		if [[ $# -lt 2 ]] || [[ -z "$2" ]]; then
			usage
			exit 1
		fi
		resume_task "$2"
		;;
	--clean)
		clean_tasks "$CLEAN_DAYS" "$DRY_RUN"
		;;
	--prune)
		prune_completed "$DRY_RUN"
		;;
	*)
		create_task "$1"
		;;
	esac
}

main "$@"
