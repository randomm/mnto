#!/usr/bin/env bash
set -euo pipefail

# mnto — Minimalist task orchestrator
# Usage: mnto "goal" | mnto --resume {tid} | mnto --list | mnto --dry-run | mnto --plan-model {url} | mnto --vipune

# SCRIPT_DIR can be overridden via env for testing
SCRIPT_DIR="${SCRIPT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"
readonly SCRIPT_DIR
readonly BB_DIR=".mnto/bb"

# Backward compatibility: detect existing .bb/ and migrate
if [[ -d ".bb" ]] && [[ ! -L ".bb" ]] && [[ -n "$(ls -A .bb 2>/dev/null)" ]] && [[ ! -d ".mnto/bb" ]]; then
	# Security: Verify ownership before migration
	_owner="$(stat -c '%u' .bb 2>/dev/null || stat -f '%u' .bb 2>/dev/null)"
	if [[ "$_owner" != "$(id -u)" ]]; then
		echo "ERROR: .bb is owned by another user (uid $_owner). Manual migration required." >&2
		exit 1
	fi

	# Security: Require explicit opt-in for migration
	if [[ "${MIGRATE_BB:-}" != "yes" ]]; then
		echo "WARNING: Found existing .bb/ tasks. To migrate, run with MIGRATE_BB=yes" >&2
		exit 1
	fi

	echo "Migrating .bb/ to .mnto/bb/..."
	mkdir -p .mnto
	# Atomic non-clobbering move
	mv -n .bb .mnto/bb
	echo "Migration complete. Your tasks are now in .mnto/bb/"
fi

# Dependency tree:
# mnto
# ├── blackboard.bash
# ├── planner.bash
# ├── harness.bash (depends on: blackboard.bash, planner.bash)
# ├── stitcher.bash (depends on: blackboard.bash, planner.bash)
# └── maintenance.bash (depends on: blackboard.bash)

# Source library functions
source "$SCRIPT_DIR/lib/blackboard.bash"
source "$SCRIPT_DIR/lib/maintenance.bash"
source "$SCRIPT_DIR/lib/planner.bash"
source "$SCRIPT_DIR/lib/harness.bash"
source "$SCRIPT_DIR/lib/stitcher.bash"

# Global options
declare -a REMAINING_ARGS
DRY_RUN="${DRY_RUN:-false}"
VIPUNE_ENABLED="${VIPUNE_ENABLED:-false}"
PLAN_MODEL="${PLAN_MODEL:-apfel}"
CLEAN_MODE="${CLEAN_MODE:-false}"
PRUNE_MODE="${PRUNE_MODE:-false}"
CLEAN_DAYS="${CLEAN_DAYS:-30}"

usage() {
	cat <<EOF
Usage: mnto "goal" | mnto [options]

Commands:
  mnto "goal"           Create and run new task
  mnto --resume {tid}   Resume existing task from last state
  mnto --list           List tasks with goal snippets and status
  mnto --clean [--days N] [--dry-run]
                        Remove tasks older than N days (default: 30)
  mnto --prune [--dry-run]
                        Remove completed tasks only (have output)

Options:
  -h, --help            Show this help
  --dry-run             Show actions without executing (also --clean, --prune)
  --plan-model {url}    Use external model (curl to URL or command)
  --vipune              Enable vipune semantic search integration
EOF
}

list_tasks() {
	if [[ ! -d "$BB_DIR" ]]; then
		echo "No tasks found"
		return 0
	fi

	# Enhanced list with goal snippet, subtask counts, and status
	for task_dir in "$BB_DIR"/*/; do
		if [[ -d "$task_dir" ]]; then
			local tid
			tid="$(basename "$task_dir")"

			# Get goal snippet
			local snippet
			snippet="$(get_goal_snippet "$tid")"

			# Get subtask counts
			local counts
			counts="$(count_subtasks "$tid")"
			read -r w d c f <<<"$counts"

			# Get overall task status
			local status
			status="$(get_task_status "$tid")"

			# Format: {tid} {goal_snippet} {w|d|c|f} {status}
			printf '%s %s %s/%s/%s/%s %s\n' "$tid" "$snippet" "$w" "$d" "$c" "$f" "$status"
		fi
	done
}

create_task() {
	local goal="$1"

	# Check for vipune integration
	if [[ "$VIPUNE_ENABLED" == "true" ]]; then
		# Search for relevant context
		local vipune_context
		vipune_context="$(vipune_search "$goal")"
		if [[ -n "$vipune_context" ]]; then
			# Prepend vipune results to goal
			goal="$goal$vipune_context"
		fi
	fi

	mkdir -p "$BB_DIR"

	# Generate task ID (with collision detection)
	local tid
	tid="$(gen_id)"
	local bb_dir="$BB_DIR/$tid"

	# Create task directory
	mkdir -p "$bb_dir"

	# Save goal
	echo "$goal" >"$bb_dir/g"

	# Generate plan using planner module (respects PLAN_MODEL)
	local plan
	local plan_result
	plan="$(generate_plan "$goal")"
	plan_result=$?

	if [[ $plan_result -ne 0 ]]; then
		# Exit code from generate_plan contains the error reason
		rm -rf "$bb_dir"
		exit "$plan_result"
	fi

	if [[ -z "$plan" ]]; then
		echo "ERROR: Failed to generate plan" >&2
		rm -rf "$bb_dir"
		exit 1
	fi

	# Parse plan into structure
	parse_plan "$plan" "$tid"

	# Run the draft-verify harness
	run_harness "$tid"

	echo "Created task: $tid"
}

resume_task() {
	local tid="$1"
	if ! validate_id "$tid"; then
		echo "ERROR: Invalid task ID format" >&2
		exit 1
	fi
	local bb_dir="$BB_DIR/$tid"

	if [[ ! -d "$bb_dir" ]]; then
		echo "ERROR: Task '$tid' not found" >&2
		exit 1
	fi

	# Read current state and find next waiting subtask
	local status_file="$bb_dir/s"
	if [[ ! -f "$status_file" ]]; then
		echo "ERROR: Task '$tid' has no status file" >&2
		exit 1
	fi

	# Find first subtask that is not yet final
	local next_subtask=""
	while IFS=' ' read -r subtask_id state retries; do
		if [[ "$state" != "f" ]]; then
			next_subtask="$subtask_id"
			break
		fi
	done <"$status_file"

	if [[ -z "$next_subtask" ]]; then
		# All done - just stitch
		print_status "INFO" "All subtasks complete, stitching output"
		if stitch_task "$tid"; then
			print_status "PASS" "Task $tid completed (resumed)"
		else
			print_status "FAIL" "Failed to stitch task $tid"
			exit 1
		fi
	else
		# Resume from next subtask
		print_status "INFO" "Resuming task $tid from subtask $next_subtask"

		# Process remaining subtasks in loop
		while [[ -n "$next_subtask" ]]; do
			print_status "INFO" "Processing subtask $next_subtask"

			if ! process_subtask "$tid" "$next_subtask"; then
				print_status "FAIL" "Subtask $next_subtask: max retries exceeded or failed"
			fi

			# Find next waiting subtask
			next_subtask="$(next_task "$tid")"
			if [[ "$next_subtask" == "NULL" ]]; then
				next_subtask=""
			fi
		done

		# Stitch all final drafts
		if ! stitch_task "$tid"; then
			echo "ERROR: Failed to stitch task $tid" >&2
			exit 1
		fi
		print_status "PASS" "Task $tid completed (resumed)"
	fi

	echo "Resumed task: $tid"
}

parse_options() {
	local _remaining_args=()
	while [[ $# -gt 0 ]]; do
		case "$1" in
		-h | --help)
			usage
			exit 0
			;;
		--dry-run)
			DRY_RUN="true"
			shift
			;;
		--plan-model)
			if [[ $# -lt 2 ]]; then
				echo "ERROR: --plan-model requires a URL or command" >&2
				exit 1
			fi
			PLAN_MODEL="$2"
			shift 2
			;;
		--vipune)
			VIPUNE_ENABLED="true"
			shift
			;;
		--clean)
			CLEAN_MODE="true"
			shift
			;;
		--prune)
			PRUNE_MODE="true"
			shift
			;;
		--days)
			if [[ $# -lt 2 ]]; then
				echo "ERROR: --days requires a number" >&2
				exit 1
			fi
			if ! [[ "$2" =~ ^[0-9]+$ ]]; then
				echo "ERROR: --days requires a positive integer" >&2
				exit 1
			fi
			CLEAN_DAYS="$2"
			shift 2
			;;
		-*)
			echo "ERROR: Unknown option: $1" >&2
			usage
			exit 1
			;;
		*)
			_remaining_args+=("$1")
			shift
			;;
		esac
	done
	REMAINING_ARGS=("${_remaining_args[@]}")
}

main() {
	if [[ $# -eq 0 ]]; then
		usage
		exit 1
	fi

	# Parse global options first
	parse_options "$@"
	set -- "${REMAINING_ARGS[@]}"

	case "$1" in
	-h | --help)
		usage
		exit 0
		;;
	--list)
		list_tasks
		;;
	--resume)
		if [[ $# -lt 2 ]] || [[ -z "$2" ]]; then
			usage
			exit 1
		fi
		resume_task "$2"
		;;
	--clean)
		clean_tasks "$CLEAN_DAYS" "$DRY_RUN"
		;;
	--prune)
		prune_completed "$DRY_RUN"
		;;
	*)
		create_task "$1"
		;;
	esac
}

main "$@"
